-- POT ME (SD ONLY) - wymaga wielu shooterow

-- CONFIG
local WINDOW_MS     = 2000
local HITS_NEEDED   = 5
local MIN_SHOOTERS  = 5      -- <- ile roznych graczy musi trafic SD w oknie czasu (np. 2/3/4)
local ICON_ID       = 238
local MP_THRESHOLD  = 85
local ALERT_CD_MS   = 2000
local SD_MISSILE_ID = 32

-- hit = {t = now, shooterId = number}
local hits = {}
local alertCdUntil = 0

local function inCooldown()
  return now < alertCdUntil
end

local function lockAlert(msCd)
  alertCdUntil = now + (msCd or ALERT_CD_MS)
end

local function resetHits()
  hits = {}
end

local function pruneOldHits()
  local cutoff = now - WINDOW_MS
  while hits[1] and hits[1].t < cutoff do
    table.remove(hits, 1)
  end
end

local function pushHit(shooterId)
  hits[#hits+1] = { t = now, shooterId = shooterId }
  pruneOldHits()
end

local function hitCount()
  return #hits
end

local function distinctShooters()
  pruneOldHits()
  local seen = {}
  local count = 0
  for _, h in ipairs(hits) do
    local sid = h.shooterId
    if sid and not seen[sid] then
      seen[sid] = true
      count = count + 1
    end
  end
  return count
end

-- Zwraca shooterId tylko jesli na tile zrodla jest DOKLADNIE 1 gracz (inny niz ty).
-- Jak jest 0 albo >1, zwraca nil (unikamy falszywek).
local function getSingleShooterId(missle)
  local src = missle:getSource()
  if not src then return nil end

  local tile = g_map.getTile(src)
  if not tile then return nil end

  local creatures = tile:getCreatures()
  if not creatures then return nil end

  local lp = g_game.getLocalPlayer()
  local meId = lp and lp:getId() or nil
  if not meId then return nil end

  local foundId = nil
  for _, c in ipairs(creatures) do
    if c and c:isPlayer() then
      local cid = c:getId()
      if cid and cid ~= meId then
        if foundId and foundId ~= cid then
          return nil -- >1 gracz na tile zrodla -> nie wiemy kto strzelil
        end
        foundId = cid
      end
    end
  end
  return foundId
end

local potMeMacro = macro(100, "POT ME SD", function()
  if inCooldown() then return end
  if hitCount() < HITS_NEEDED then return end
  if distinctShooters() < MIN_SHOOTERS then return end
  if manapercent() >= MP_THRESHOLD then return end
  if not hasManaShield() then return end

  say("POT ME")
  lockAlert(ALERT_CD_MS)
  resetHits()
end)
potMeMacro:setOff()

addIcon("PotMeIcon", {
  item = ICON_ID,
  text = "POT ME",
  movable = true,
  switchable = true
}, function(widget, enabled)
  if enabled then
    potMeMacro:setOn()
  else
    potMeMacro:setOff()
    resetHits()
  end
end)

onMissle(function(missle)
  if not potMeMacro:isOn() then return end
  if inCooldown() then return end

  -- tylko SD
  if missle:getId() ~= SD_MISSILE_ID then return end

  -- tylko gdy leci w ciebie
  local dst = missle:getDestination()
  if not dst then return end

  local p = pos()
  if not p or p.z ~= dst.z then return end
  if p.x ~= dst.x or p.y ~= dst.y then return end

  -- shooter
  local shooterId = getSingleShooterId(missle)
  if not shooterId then return end

  pushHit(shooterId)
end)

