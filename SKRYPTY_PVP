local kolorowanie = macro(100, "KOLOROWANIE", function()
  local me = g_game.getLocalPlayer()
  if not me then return end

  local commander = (storage.Commander or ""):lower()

  for _, c in ipairs(getSpectators()) do
    if c and c:isPlayer() and not c:isLocalPlayer() then

      local name = c:getName()
      local nameLower = name:lower()
      local emblem = c:getEmblem()

      local kolor = nil
      local tekst = ""

      -- Commander (priorytet nad wszystkim)
      if commander ~= "" and nameLower == commander then
        kolor = "yellow"
        tekst = "\n[C]"

      -- Enemy: emblem 2 / 3 LUB Enemy List z bota
      elseif emblem == 2
         or emblem == 3
         or (storage.playerList
             and storage.playerList.enemyList
             and table.find(storage.playerList.enemyList, name, true)) then

        kolor = "red"
        tekst = "\n[E]"

      -- Ally: emblem 1
      elseif emblem == 1 then
        kolor = "green"
        tekst = "\n[F]"
      end

      -- Ustaw kolor lub zresetuj
      if kolor then
        c:setInformationColor(kolor)
        c:setText(tekst, kolor)
        c:showStaticSquare(kolor)
      else
        -- reset jesli nie pasuje do zadnej kategorii
        c:setText("")
        c:setInformationColor("green")
      end
    end
  end
end)

