-- GUILD HEALING MS/ED/RP/EK

guildhealing = macro(200, "Guild Healing", function()
  if not myVocation then return end -- czekaj az wykryje profesje

  local myPlayer = g_game.getLocalPlayer()
  if not myPlayer then return end

  local myPosition = myPlayer:getPosition()

  for _, creature in ipairs(getSpectators()) do
    if creature
      and creature:isPlayer()
      and creature:getEmblem() == 1
      and not creature:isLocalPlayer() then

      local healthPercent = creature:getHealthPercent()
      if healthPercent <= 80 then

        -- ED → exura sio (mana > 30%)
        if myVocation == "ED" then
          if manapercent() > 30 then
            saySpell('exura sio "' .. creature:getName() .. '"', 100)
          end

        -- MS → UH (mana > 30%)
        elseif myVocation == "MS" then
          if manapercent() > 30 then
            useWith(3160, creature)
          end

        -- EK + RP → UH (HP > 80%) + tylko 1 sqm
        elseif myVocation == "EK" or myVocation == "RP" then
          local creaturePosition = creature:getPosition()
          if creaturePosition
            and getDistanceBetween(creaturePosition, myPosition) <= 1
            and hppercent() > 80 then
            useWith(3160, creature)
          end
        end
      end
    end
  end
end)

