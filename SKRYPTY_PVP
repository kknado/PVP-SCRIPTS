local hotkeyRuna = "" -- Wpisz hotkey w puste miejsce, jezeli chcesz miec parala pod hotkeyem

local function isOnScreen(p1, p2)
  return math.abs(p1.x - p2.x) <= 7 and math.abs(p1.y - p2.y) <= 5
end

local function distance(p1, p2)
  return math.max(math.abs(p1.x - p2.x), math.abs(p1.y - p2.y))
end

function autoParalRuna()
  if not isInPz() then
      if not g_game.isSafeFight() then
          local target = g_game.getAttackingCreature()
          if target and target:isPlayer() then
              if target:canShoot() and manapercent() > 80 then
                  useWith(3165, target)
                  delay(100)
              else
                  g_game.cancelAttack()
              end
          else
              for _, creature in ipairs(getSpectators()) do
                  if creature:isPlayer() then
                      local isEnemy = isEnemy(creature:getName())
                      local hasEmblem3 = (creature:getEmblem() == 2)
                      if isEnemy or hasEmblem3 then
                          if creature:canShoot() and manapercent() > 80 and isOnScreen(g_game.getLocalPlayer():getPosition(), creature:getPosition()) then
                              g_game.attack(creature)
                              useWith(3165, target)
                              delay(100)
                              break
                          end
                      end
                  end
              end
          end
      end
  end
end

