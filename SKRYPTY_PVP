-- AUTO-FLOWER

storage.autoFlower = storage.autoFlower or {
  itemId      = 2981,      -- ID itemu (kwiatka)
  hotkey      = "1",       -- klawisz do zaznaczania pola
  text        = "FLOWER",  -- napis na polu
  textColor   = "yellow",  -- kolor napisu
  maxFlowers  = 1,         -- ile sztuk ma leżeć na polu
  maxDistance = 8,         -- max odległość od gracza (x/y)
  enabled     = true       -- globalny ON/OFF refill (tylko z configu)
}

local cfg = storage.autoFlower

-- Zaznaczone pola: key = "x,y,z", value = {x=..,y=..,z=..}
local flowerTiles = {}

local function posToKey(pos)
  return string.format("%d,%d,%d", pos.x, pos.y, pos.z)
end

local function keyToPos(key)
  local x, y, z = key:match("^(%-?%d+),(%-?%d+),(%-?%d+)$")
  if not x then return nil end
  return { x = tonumber(x), y = tonumber(y), z = tonumber(z) }
end

-- Hotkey: zaznaczanie / odznaczanie pola pod kursorem
onKeyPress(function(key)
  if not cfg.enabled then
    return
  end

  if key:lower() ~= tostring(cfg.hotkey):lower() then
    return
  end

  local tile = getTileUnderCursor()
  if not tile then
    return
  end

  local pos    = tile:getPosition()
  local keyStr = posToKey(pos)

  if flowerTiles[keyStr] then
    -- Odznacz: usuń napis i z tabeli
    tile:setText("")
    flowerTiles[keyStr] = nil
  else
    -- Zaznacz: ustaw napis i zapamiętaj pozycję
    tile:setText(cfg.text, cfg.textColor)
    flowerTiles[keyStr] = { x = pos.x, y = pos.y, z = pos.z }
  end
end)

-- Zapamiętujemy ostatnie Z, żeby wykrywać zejście/wejście po schodach
local lastZ = pos().z

-- Makro do uzupełniania itemów na oznaczonych polach
local autoFlowerMacro = macro(1, function()
  if not cfg.enabled then
    return
  end

  local playerPos = pos()

  -- Zmiana piętra → czyścimy wszystkie FLOWER-y z poprzedniego Z
  if playerPos.z ~= lastZ then
    for keyStr, storedPos in pairs(flowerTiles) do
      local posData = storedPos or keyToPos(keyStr)
      if posData and posData.z == lastZ then
        local tile = g_map.getTile(posData)
        if tile and tile:getText() == cfg.text then
          tile:setText("") -- usuwamy napis
        end
      end
    end
    flowerTiles = {}
    lastZ = playerPos.z
    return -- ten tick pomijamy refill
  end

  for keyStr, storedPos in pairs(flowerTiles) do
    local posData = storedPos or keyToPos(keyStr)
    if not posData then
      flowerTiles[keyStr] = nil
    else
      local dx = math.abs(playerPos.x - posData.x)
      local dy = math.abs(playerPos.y - posData.y)

      -- za daleko albo inne piętro → nie uzupełniamy
      if dx > (cfg.maxDistance or 8) or dy > (cfg.maxDistance or 8) or playerPos.z ~= posData.z then
        -- opcjonalnie można czyścić:
        -- flowerTiles[keyStr] = nil
      else
        local tile = g_map.getTile(posData)
        if not tile then
          -- tile zniknął (np. inna mapa) → czyścimy
          flowerTiles[keyStr] = nil
        else
          -- NOWY WARUNEK: jeśli z jakiegoś powodu napis już nie jest FLOWER,
          -- traktujemy to jako odznaczone pole (nie refilliujemy)
          if tile:getText() ~= cfg.text then
            flowerTiles[keyStr] = nil
          else
            local count = 0
            local items = tile:getItems() or {}

            -- policz ile itemów już leży
            for _, item in ipairs(items) do
              if item:getId() == cfg.itemId then
                count = count + item:getCount()
              end
            end

            -- jeśli mniej niż maxFlowers → dorzuć z plecaków
            if count < (cfg.maxFlowers or 1) then
              local stack = findItem(cfg.itemId)
              if stack then
                g_game.move(stack, posData, 1)
              end
            end
          end
        end
      end
    end
  end
end)

if not cfg.enabled then
  autoFlowerMacro:setOff()
end


