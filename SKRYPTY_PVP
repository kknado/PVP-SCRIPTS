local emblematFriends = 1
local emblematEnemy = 2

local function pobierzEmblemat(istota)
  if not istota or not istota.getEmblem then return nil end
  return istota:getEmblem()
end

local function policzNaEkranie()
  local mojaPos = pos()
  if not mojaPos then return 0, 0 end

  local widoczni = g_map.getSpectators(mojaPos, false) or {}
  local friends = 0
  local enemy = 0

  for _, istota in ipairs(widoczni) do
    if istota
       and istota:isPlayer() then

      local embl = pobierzEmblemat(istota)

      if embl == emblematFriends then
        friends = friends + 1
      elseif embl == emblematEnemy then
        enemy = enemy + 1
      end
    end
  end

  return friends, enemy
end

local function wyslijNaCzat()
  local friends, enemy = policzNaEkranie()
  say(string.format("%d BRACI %d CWELOW", friends, enemy))
end

