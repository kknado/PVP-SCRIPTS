-- DASH

local walkMarkerText = "WALK"
local lastKeyPressTime = 0
local walkHotkey = storage.keyWalk or "F8"
local clearHotkey = storage.clearKey or "Space"
local markedPositions = {}
local getDirectionFromPos = modules.corelib.getDirectionFromPos
local markedTilesHistory = {}

local function isWsadWalkingEnabled()
    return modules.client_options.getOption("wsadWalking") == true
end

local function findMarkedPositionIndex(position)
    for index, markedPos in pairs(markedPositions) do
        if markedPos.x == position.x and markedPos.y == position.y then
            return index
        end
    end

    return nil
end

local function findTileHistoryIndex(position)
    for index, tilePos in pairs(markedTilesHistory) do
        if tilePos.x == position.x and tilePos.y == position.y then
            return index
        end
    end

    return nil
end

local dashWalkMacro = macro(1, "Dash Walk", function()
    if not isWsadWalkingEnabled() or not markedPositions[1] then
        return
    end

    local playerPos = player:getPosition()

    for _, targetPos in pairs(markedPositions) do
        if getDistanceBetween(playerPos, targetPos) == 1 then
            local direction = getDirectionFromPos(playerPos, targetPos)
            if direction then
                g_game.walk(direction)
            end
        end
    end
end)

onKeyDown(function(keyPressed)
    if not isWsadWalkingEnabled() or dashWalkMacro.isOff() then
        return
    end

    if keyPressed == walkHotkey then
        lastKeyPressTime = now
        local tileUnderCursor = getTileUnderCursor()

        if not tileUnderCursor then
            return
        end

        local tilePosition = tileUnderCursor:getPosition()
        local markedIndex = findMarkedPositionIndex(tilePosition)

        if markedIndex then
            tileUnderCursor:setText("")
            table.remove(markedPositions, markedIndex)
            local historyIndex = findTileHistoryIndex(tilePosition)
            if historyIndex then
                table.remove(markedTilesHistory, historyIndex)
            end
        else
            tileUnderCursor:setText(walkMarkerText, "#a1ff0a")
            table.insert(markedPositions, tilePosition)
            table.insert(markedTilesHistory, tilePosition)
        end
    elseif keyPressed == clearHotkey then
        for _, tilePos in ipairs(markedTilesHistory) do
            local tile = g_map.getTile(tilePos)
            if tile then
                tile:setText("")
            end
        end
        table.clear(markedPositions)
        table.clear(markedTilesHistory)
    end
end)

onKeyPress(function(keyPressed)
    if not isWsadWalkingEnabled() or dashWalkMacro.isOff() then
        return
    end

    if keyPressed ~= walkHotkey then
        return
    end

    if lastKeyPressTime - now < -500 then
        for _, tile in ipairs(g_map.getTiles(posz())) do
            if tile:getText() == walkMarkerText then
                tile:setText("")
            end
        end
        table.clear(markedPositions)
        table.clear(markedTilesHistory)
    end
end)

onPlayerPositionChange(function(newPosition, oldPosition)
    if not isWsadWalkingEnabled() or dashWalkMacro.isOff() then
        return
    end

    local markedIndex = findMarkedPositionIndex(newPosition)
    if markedIndex then
        table.remove(markedPositions, markedIndex)
        local tile = g_map.getTile(newPosition)
        if tile then
            tile:setText("")
        end
    end
end)

