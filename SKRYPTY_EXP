-- NIE POTUJE KIEDY LOOTUJE

vBot = vBot or {}
storage.extras = storage.extras or {}

if storage.extras.noPotionsWhileLooting == nil then
  storage.extras.noPotionsWhileLooting = true
end
vBot.noPotionsWhileLooting = storage.extras.noPotionsWhileLooting

local ui = setupUI([[
Panel
  height: 19

  BotSwitch
    id: noPots
    anchors.left: parent.left
    anchors.right: parent.right
    text-align: center
    !text: tr('NIE POTUJE JAK LOOTUJE')
    font: verdana-11px-rounded
]])

ui.noPots:setOn(storage.extras.noPotionsWhileLooting)

ui.noPots.onClick = function(widget)
  local enabled = not widget:isOn()
  widget:setOn(enabled)

  vBot.noPotionsWhileLooting = enabled
  storage.extras.noPotionsWhileLooting = enabled

  warn("Nie potuje kiedy lootuje: " .. (enabled and "ON" or "OFF"))
end
