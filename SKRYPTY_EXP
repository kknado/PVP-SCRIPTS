setDefaultTab("EXP")

local TAB_NAME = "EXP"
local KOLOR = "#ffff00"

local function znajdzPierwszyZTekstem(widget, szukany)
  if not widget then return nil end
  if widget.getText and widget:getText() == szukany then return widget end
  for _, ch in ipairs(widget:getChildren() or {}) do
    local f = znajdzPierwszyZTekstem(ch, szukany)
    if f then return f end
  end
  return nil
end

local function wymusKolor(tabBtn)
  if tabBtn and tabBtn.setColor then
    tabBtn:setColor(KOLOR)
  end
end

schedule(200, function()
  local root = g_ui.getRootWidget()
  local tabBtn = znajdzPierwszyZTekstem(root, TAB_NAME)
  if not tabBtn then return end

  wymusKolor(tabBtn)

  tabBtn.onStyleApply = function(widget)
    wymusKolor(widget)
  end

  if tabBtn.onHoverChange ~= nil then
    tabBtn.onHoverChange = function(widget, hovered)
      wymusKolor(widget)
    end
  end
end)  

